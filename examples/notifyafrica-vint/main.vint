    print("=" * 50)
    print("VintLang Features Demonstrated")
    print("=" * 50)
    
    print("Modules Used:")
    print("  notifyafrica_pkg - Custom SMS API package")
    print("  os - File operations and existence checks")
    print("  time - Time formatting and current time")
    print("  uuid - Unique ID generation")
    print("  dotenv - Environment variable management")
    print("  json - JSON encoding for data structures")
    print("  crypto - MD5 hashing for security")
    print("  random - Random number generation")
    print("  sysinfo - System information retrieval")
    print("  string - String manipulation and conversion")
    print("  cli - Command-line argument parsing")
    
    print("\nLanguage Features Used:")
    print("  Functions with parameters and return values")
    print("  Dictionaries and arrays")
    print("  For loops and conditional statements")
    print("  File I/O operations")
    print("  Error handling and validation")
    print("  Command-line argument processing")
    print("  Type conversion and string operations")
    
    print("\nApplication Features:")
    print("  SMS sending with multiple options")
    print("  Random verification code generation")
    print("  Real-time statistics tracking")
    print("  Secure logging with MD5 hashes")
    print("  System information display")
    print("  Environment configuration management")
    print("  Comprehensive activity logging")
    print("  Command-line interface")
}

// View log function for CLI
let viewLog = func() {
    let log_file = "notifyafrica.log"
    print("=" * 40)
    print("Application Logs")
    print("=" * 40)
    
    if (os.fileExists(log_file)) {
        let logs = os.readFile(log_file)
        print(logs)
    } else {
        print("No logs available yet.")
    }
}

// Show help information
let showHelp = func() {
    print(app_name + " v" + version)
    print("Command-line SMS sender showcasing VintLang features")
    print("")
    print("Usage:")
    print("  vint main.vint [command] [options]")
    print("")
    print("Commands:")
    print("  send              Send SMS")
    print("    --sender-id     Sender ID (required)")
    print("    --message       SMS message (required)")
    print("    --recipients    Comma-separated phone numbers (required)")
    print("    --schedule      Schedule (optional, default: none)")
    print("")
    print("  verify            Send verification SMS")
    print("    --sender-id     Sender ID (required)")
    print("    --phone         Recipient phone number (required)")
    print("    --name          Recipient name (required)")
    print("")
    print("  dashboard         Show system dashboard and statistics")
    print("  logs              View application logs")
    print("  features          Show VintLang features demonstrated")
    print("  help              Show this help message")
    print("")
    print("Examples:")
    print("  vint main.vint send --sender-id MySender --message \"Hello World\" --recipients \"+1234567890,+0987654321\"")
    print("  vint main.vint verify --sender-id MySender --phone \"+1234567890\" --name \"John Doe\"")
    print("  vint main.vint dashboard")
}

// Initialize application with environment check
let initApp = func() {
    // Check environment using dotenv
    let token = dotenv.get("NOTIFYAFRICA_TOKEN")
    if (token == "") {
        print("Warning: No valid API token found!")
        print("Please set NOTIFYAFRICA_TOKEN in your .env file")
    } else if (token == "your_api_token_here") {
        print("Warning: No valid API token found!")
        print("Please set NOTIFYAFRICA_TOKEN in your .env file")
    }
    
    // logResult("INFO", "Application started - " + app_name + " v" + version)
}

// Main CLI application logic
let main = func() {
    // Initialize the application
    initApp()
    
    // Get command line arguments
    let args = cli.getPositional()
    
    if (len(args) < 1) {
        showHelp()
    } else {
        let command = args[0]
        
        if (command == "send") {
            let senderId = cli.getArgValue("--sender-id")
            let message = cli.getArgValue("--message")
            let recipients = cli.getArgValue("--recipients")
            let schedule = cli.getArgValue("--schedule")
            
            if (senderId == null) {
                print("Error: Missing required argument --sender-id")
            } else if (message == null) {
                print("Error: Missing required argument --message")
            } else if (recipients == null) {
                print("Error: Missing required argument --recipients")
            } else {
                if (schedule == null) { schedule = "none" }
                sendSMS(senderId, message, recipients, schedule)
            }
            
        } else if (command == "verify") {
            let senderId = cli.getArgValue("--sender-id")
            let phone = cli.getArgValue("--phone")
            let name = cli.getArgValue("--name")
            
            if (senderId == null) {
                print("Error: Missing required argument --sender-id")
            } else if (phone == null) {
                print("Error: Missing required argument --phone")
            } else if (name == null) {
                print("Error: Missing required argument --name")
            } else {
                sendVerificationSMS(senderId, phone, name)
            }
            
        } else if (command == "dashboard") {
            showDashboard()
            
        } else if (command == "logs") {
            viewLog()
            
        } else if (command == "features") {
            showFeatures()
            
        } else if (command == "help") {
            showHelp()
            
        } else {
            print("Error: Unknown command '" + command + "'")
            print("Use 'help' to see available commands")
        }
    }
}

// Start the application
main()