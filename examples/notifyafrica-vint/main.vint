// Enhanced NotifyAfrica SMS Sender - Showcasing VintLang Features
import notifyafrica_pkg
import os
import time
import uuid
import dotenv
import json
import crypto
import random
import sysinfo
import string
import cli

// Load environment variables
dotenv.load(".env")

// Global config
let app_name = "NotifyAfrica SMS Pro"
let version = "2.0.0"
let stats_file = "sms_stats.json"

// Enhanced logging with security hash and better formatting
let logResult = func(level, logMessage) {
    let log_file = "notifyafrica.log"
    let timestamp = time.format(time.now(), "2006-01-02 15:04:05")
    
    // Add security hash using crypto module
    let hash = crypto.hashMD5(logMessage + "security_salt")
    let fullLog = "[" + timestamp + "] [" + level + "] " + logMessage + " (Hash: " + hash + ")\n"
    
    os.writeFile(log_file, fullLog, "append")
    
    // Display with better formatting (simplified for CLI)
    if (level == "ERROR") {
        print("[ERROR] " + logMessage)
    } else if (level == "SUCCESS") {
        print("[SUCCESS] " + logMessage)
    } else if (level == "INFO") {
        print("[INFO] " + logMessage)
    } else {
        print("[" + level + "] " + logMessage)
    }
}

// Load statistics from file
let loadStats = func() {
    if (os.fileExists(stats_file)) {
        let statsData = os.readFile(stats_file)
        if (statsData != "") {
            return json.decode(statsData)
        }
    }
    return {"total_sent": 0, "total_failed": 0}
}

// Save statistics to file
let saveStats = func(stats) {
    let statsJson = json.encode(stats)
    os.writeFile(stats_file, statsJson, "write")
}

// Generate random verification code using random module
let generateVerificationCode = func() {
    return string(random.int(100000, 999999))
}

// Parse recipients from command line argument
let parseRecipients = func(recipientsStr) {
    let recipients = []
    let nums = recipientsStr.split(",")
    for n in nums {
        let trimmed = n.trim()
        if (trimmed != "") {
            recipients.push({"number": trimmed})
        }
    }
    return recipients
}

// Send SMS function for CLI
let sendSMS = func(senderId, message, recipientsStr, schedule) {
    let recipients = parseRecipients(recipientsStr)
    let request_id = uuid.generate()
    
    print("Sending SMS... [Request ID: " + request_id + "]")
    print("Recipients: " + string(len(recipients)))
    
    let response = notifyafrica_pkg.sendSMS(senderId, message, recipients, schedule)
    
    // Load current stats
    let stats = loadStats()
    
    // Enhanced error handling with stats tracking
    if (response.type) {
        if (response.type() == "ERROR") {
            logResult("ERROR", "Failed to send SMS: " + response.message() + " [Request ID: " + request_id + "]")
            stats["total_failed"] = stats["total_failed"] + 1
        } else {
            logResult("SUCCESS", "SMS sent to " + string(len(recipients)) + " recipients [Request ID: " + request_id + "]")
            stats["total_sent"] = stats["total_sent"] + len(recipients)
        }
    } else {
        logResult("SUCCESS", "SMS sent to " + string(len(recipients)) + " recipients [Request ID: " + request_id + "]")
        stats["total_sent"] = stats["total_sent"] + len(recipients)
    }
    
    // Save updated stats
    saveStats(stats)
}

// Send SMS with verification code function for CLI
let sendVerificationSMS = func(senderId, phone, name) {
    // Generate random verification code
    let code = generateVerificationCode()
    let message = "Hello " + name + "! Your verification code is: " + code + ". Valid for 10 minutes. Thank you!"
    
    print("Generated verification code: " + code)
    print("Message: " + message)
    
    let recipients = [{"number": phone}]
    let request_id = uuid.generate()
    
    print("Sending verification SMS... [Request ID: " + request_id + "]")
    
    let response = notifyafrica_pkg.sendSMS(senderId, message, recipients, "none")
    
    // Load current stats
    let stats = loadStats()
    
    // Enhanced error handling and logging
    if (response.type) {
        if (response.type() == "ERROR") {
            logResult("ERROR", "Failed to send verification SMS: " + response.message() + " [Request ID: " + request_id + "]")
            stats["total_failed"] = stats["total_failed"] + 1
        } else {
            logResult("SUCCESS", "Verification SMS sent to " + phone + " [Code: " + code + "] [Request ID: " + request_id + "]")
            stats["total_sent"] = stats["total_sent"] + 1
        }
    } else {
        logResult("SUCCESS", "Verification SMS sent to " + phone + " [Code: " + code + "] [Request ID: " + request_id + "]")
        stats["total_sent"] = stats["total_sent"] + 1
    }
    
    // Save updated stats
    saveStats(stats)
}

// Dashboard function for CLI
let showDashboard = func() {
    print("=" * 60)
    print(app_name + " Dashboard")
    print("=" * 60)
    
    // System information using sysinfo module
    print("System Information:")
    print("  OS: " + sysinfo.os())
    print("  Architecture: " + sysinfo.arch())
    print("  Current Time: " + time.format(time.now(), "2006-01-02 15:04:05"))
    
    // Load and display statistics
    let stats = loadStats()
    print("\nSMS Statistics:")
    print("  Total SMS Sent: " + string(stats["total_sent"]))
    print("  Total Failed: " + string(stats["total_failed"]))
    
    let total = stats["total_sent"] + stats["total_failed"]
    if (total > 0) {
        let successRate = (stats["total_sent"] * 100) / total
        print("  Success Rate: " + string(successRate) + "%")
    } else {
        print("  Success Rate: N/A (No SMS sent yet)")
    }
    
    // Environment status using dotenv module
    print("\nEnvironment Configuration:")
    let token = dotenv.get("NOTIFYAFRICA_TOKEN")
    if (token != "") {
        if (token != "your_api_token_here") {
            print("  API Token: Configured")
        } else {
            print("  API Token: Not configured")
        }
    } else {
        print("  API Token: Not configured")
    }
    
    let baseUrl = dotenv.get("NOTIFYAFRICA_BASEURL")
    if (baseUrl != "") {
        print("  Base URL: " + baseUrl)
    } else {
        print("  Base URL: Using default")
    }
}

